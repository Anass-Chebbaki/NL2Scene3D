# =============================================================================
# NL2Scene3D - .gitignore
# =============================================================================

# Ambiente virtuale Python
.venv/
venv/
env/
ENV/

# Variabili d'ambiente e segreti (NON committare mai la chiave API)
.env
.env.local
.env.*.local

# File generati dalla pipeline (scene, render, JSON intermedi)
scenes/outputs/
scenes/originals/*.blend

# Log dell'applicazione
logs/
*.log

# Cache Python
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribuzione e build
dist/
build/
*.egg-info/
*.egg
.eggs/

# Cache dei tool
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# Blender file temporanei
*.blend1
*.blend2

# File di output temporanei del rendering
/tmp/