# Chiave API di Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Modello primario da usare per il riordino testuale
GEMINI_MODEL_PRIMARY=gemini-3-flash-preview

# Modello fallback per retry su errori transitori
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# Numero massimo di tentativi per chiamata API
GEMINI_MAX_RETRIES=3

# Timeout in secondi per ciascuna chiamata API
GEMINI_TIMEOUT_SECONDS=120

# Percorso alla directory delle scene .blend
SCENES_DIR=scenes/originals

# Percorso alla directory degli output
OUTPUTS_DIR=scenes/outputs

# Risoluzione dei render intermedi (preview)
RENDER_PREVIEW_WIDTH=512
RENDER_PREVIEW_HEIGHT=512
RENDER_PREVIEW_SAMPLES=64

# Risoluzione del render finale
RENDER_FINAL_WIDTH=1280
RENDER_FINAL_HEIGHT=720
RENDER_FINAL_SAMPLES=256

# Numero massimo di oggetti movibili per scena (evita prompt troppo lunghi)
MAX_MOVABLE_OBJECTS=20

# Seed per la randomizzazione (0 = casuale)
RANDOMIZER_SEED=0